{
  "name": "stellar-did-backend",
  "version": "1.0.0",
  "description": "Backend microservice for Stellar DID Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "build": "echo 'Backend build completed'",
    "docker:build": "docker build -t stellar-did-backend .",
    "docker:run": "docker run -p 3001:3001 stellar-did-backend"
  },
  "keywords": [
    "stellar",
    "did",
    "backend",
    "microservice",
    "blockchain",
    "web3"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "apollo-server-express": "^3.12.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "ethers": "^6.10.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.1",
    "graphql": "^16.6.0",
    "graphql-tools": "^8.3.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.4.0",
    "morgan": "^1.10.0",
    "node-jose": "^2.2.0",
    "opossum": "^9.0.0",
    "rate-limit-redis": "^3.0.1",
    "redis": "^4.7.1",
    "stellar-sdk": "^10.1.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.10.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.3",
    "fast-check": "^4.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFiles": [
      "<rootDir>/src/__tests__/setup.js"
    ],
    "moduleNameMapper": {
      ".*/contracts/stellar/DIDContract": "<rootDir>/src/__tests__/__mocks__/DIDContract.js"
    }
  }
}
