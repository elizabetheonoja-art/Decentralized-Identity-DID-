{
  "name": "stellar-did-platform",
  "version": "2.0.0",
  "description": "Decentralized Identity (DID) platform with three-layer architecture: Frontend, Backend, and Smart Contracts on Stellar network",
  "scripts": {
    "install:all": "npm install && npm run install:backend && npm run install:frontend",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
    "start:backend": "cd backend && npm run dev",
    "start:frontend": "cd frontend && npm start",
    "start:all": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "test:all": "npm run test:backend && npm run test:frontend",
    "test:csp": "node scripts/test-csp.js",
    "deploy:contracts": "node scripts/deploy-contracts.js",
    "deploy:rust-contracts": "node scripts/deploy-rust-contracts.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "setup": "npm run install:all && npm run deploy:contracts"
  },
  "keywords": [
    "stellar",
    "did",
    "decentralized-identity",
    "blockchain",
    "web3",
    "verifiable-credentials",
    "smart-contracts",
    "react",
    "nodejs",
    "microservices"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/stellar-did-platform.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/stellar-did-platform/issues"
  },
  "homepage": "https://github.com/yourusername/stellar-did-platform#readme"
}
